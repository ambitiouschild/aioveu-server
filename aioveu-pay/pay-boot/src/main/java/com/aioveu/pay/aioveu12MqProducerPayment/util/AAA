

// ========== 使用官方SDK的方式 ==========
// RocketMQ官方方式
Message msg = new Message("TOPIC", "TAG", "body".getBytes());
msg.setKeys("key");
msg.setDelayTimeLevel(1);
SendResult result = producer.send(msg);

// ========== 使用自定义Request的方式 ==========
// 1. 简单使用
MessageSendRequest request = new MessageSendRequest("ORDER_TOPIC", order);
messageService.send(request);

// 2. 链式调用
SendResult result = messageService.send(
    MessageSendRequestBuilder.of("ORDER_TOPIC", order)
        .bizId("1001")
        .bizType("ORDER")
        .tag("CREATE")
        .delayTime(5000L)
        .addProperty("traceId", "trace_001")
        .addHeader("source", "order-service")
        .build()
);

// 3. 带重试的发送
MessageSendRequest request = new MessageSendRequest("ORDER_TOPIC", order);
request.setRetryTimes(3);
request.setBackoffEnabled(true);

SendResult result = messageService.sendWithRetry(request);